# ─────────────────────────────────────────────
# REQUIRED: Server wallet (receives x402 USDC, owns the CC)
# ─────────────────────────────────────────────
SERVER_WALLET_ADDRESS=0x...
SERVER_PRIVATE_KEY=0x...

# ─────────────────────────────────────────────
# REQUIRED: Contract deployer (can be same as server wallet)
# ─────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...

# ─────────────────────────────────────────────
# Aave HF Guard contract addresses (set after deployment)
#
#   Step 1: npx hardhat run scripts/deploy-callback.ts --network base-sepolia
#   Step 2: npx hardhat run scripts/deploy-reactive.ts --network kopli
# ─────────────────────────────────────────────
AAVE_HF_CALLBACK_ADDRESS=
AAVE_HF_REACTIVE_ADDRESS=

# ─────────────────────────────────────────────
# Reactive Network config
#
#   REACTIVE_NETWORK_SENDER: The relayer that delivers callbacks on Base Sepolia.
#     Find at: https://dev.reactive.network/docs/callback-contracts
#
#   CRON_TICKER_ADDRESS: Kopli CRON contract (determines check frequency).
#     Find at: https://dev.reactive.network/docs/cron
# ─────────────────────────────────────────────
REACTIVE_NETWORK_SENDER=
CRON_TICKER_ADDRESS=

# ─────────────────────────────────────────────
# x402 facilitator
#   Testnet:  https://x402.org/facilitator
#   Mainnet:  https://api.cdp.coinbase.com/platform/v2/x402
# ─────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532

# ─────────────────────────────────────────────
# Optional: CDP credentials (mainnet only)
# ─────────────────────────────────────────────
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ─────────────────────────────────────────────
# RPC URLs (fallback to public RPCs if blank)
# ─────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
KOPLI_RPC_URL=https://kopli-rpc.rkt.ink

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
# Reactive Contract deployment tuning
# ─────────────────────────────────────────────
REACT_FUNDING_AMOUNT=0.5
CALLBACK_GAS_LIMIT=2000000
