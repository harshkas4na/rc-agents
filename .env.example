# ─────────────────────────────────────────────
# REQUIRED: Server wallet (receives x402 USDC, owns the CC)
# ─────────────────────────────────────────────
SERVER_WALLET_ADDRESS=0x...
SERVER_PRIVATE_KEY=0x...

# ─────────────────────────────────────────────
# REQUIRED: Contract deployer (can be same as server wallet)
# ─────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...

# ─────────────────────────────────────────────
# Aave Protection contract addresses (set after deployment)
#
#   Deploy CC first:  forge create ... --rpc-url $BASE_SEPOLIA_RPC_URL
#   Deploy RC second: forge create ... --rpc-url $LASNA_RPC_URL --value 0.1ether
# ─────────────────────────────────────────────
AAVE_PROTECTION_CALLBACK_ADDRESS=
AAVE_PROTECTION_REACTIVE_ADDRESS=

# ─────────────────────────────────────────────
# DCA Strategy contract addresses (set after deployment)
#
#   Deploy CC: forge create DCAStrategyCallback --rpc-url $BASE_SEPOLIA_RPC_URL
#   Deploy RC: forge create DCAStrategyReactive --rpc-url $LASNA_RPC_URL --value 0.1ether
# ─────────────────────────────────────────────
DCA_STRATEGY_CALLBACK_ADDRESS=
DCA_STRATEGY_REACTIVE_ADDRESS=

# ─────────────────────────────────────────────
# x402 facilitator
#   Testnet:  https://x402.org/facilitator
#   Mainnet:  https://api.cdp.coinbase.com/platform/v2/x402
# ─────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532

# ─────────────────────────────────────────────
# Optional: CDP credentials (mainnet only)
# ─────────────────────────────────────────────
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ─────────────────────────────────────────────
# RPC URLs
# ─────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
LASNA_RPC_URL=https://lasna-rpc.rnk.dev/

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
# Bridge mode (dry = log only, live = execute swap + bridge)
# ─────────────────────────────────────────────
BRIDGE_MODE=dry
